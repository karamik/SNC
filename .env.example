# Токен бота Telegram (обязательно замените на свой)
BOT_TOKEN=your_bot_token_here

# URL базы данных PostgreSQL
DATABASE_URL=postgresql+asyncpg://star_user:star_password@db:5432/star_db

# URL Redis
REDIS_URL=redis://redis:6379/0

# Базовый URL вашего API (для Mini App и вебхуков)
API_BASE_URL=https://your-domain.com

# Секретный ключ для JWT и прочих подписей
SECRET_KEY=your-super-secret-key-change-this

# ID администраторов (через запятую)
ADMIN_IDS=123456789,987654321

# Ссылка для баннера "Звёзды здесь"
BANNER_LINK=https://t.me/starsobot_bot?start=438850682
